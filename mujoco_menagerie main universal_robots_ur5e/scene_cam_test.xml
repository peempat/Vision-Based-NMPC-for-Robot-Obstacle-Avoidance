<mujoco model="cam test — bottle viewer">

  <statistic center="0.4 0 0.3" extent="1.2"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.2 0.2 0.2" specular="0 0 0"/>
    <rgba haze="0.1 0.15 0.25 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.25 0.4 0.6" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.25 0.32 0.42" rgb2="0.15 0.20 0.28" markrgb="0.7 0.7 0.7"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.15"/>
    <material name="bottle_mat"  rgba="0.95 0.15 0.05 0.9"/>
    <material name="safety_mat"  rgba="1.0  0.85 0.0  0.15"/>
  </asset>

  <worldbody>
    <light pos="0.5 0.0 2.0" dir="0 0 -1" directional="true"/>
    <light pos="-0.5 0.5 1.0" dir="0.3 -0.3 -0.8" directional="true"
           diffuse="0.3 0.3 0.3"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Bottle markers — parked far away until detected -->
    <body name="bottle_0" mocap="true" pos="10 0 0">
      <geom type="cylinder" size="0.04 0.115" material="bottle_mat"
            contype="0" conaffinity="0"/>
      <geom type="sphere"   size="0.12"       material="safety_mat"
            contype="0" conaffinity="0"/>
    </body>
    <body name="bottle_1" mocap="true" pos="10 1 0">
